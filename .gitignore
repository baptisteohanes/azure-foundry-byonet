# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plan output
*.tfplan
*.plan

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars
!*.example.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Local/editor artifacts
.vscode/
.idea/
.DS_Store
